def cross_reference_dark_vessels(sea_bounding_box, target_time):
    ee.Initialize()
    roi = ee.Geometry.Rectangle(sea_bounding_box)  # [min_lon, min_lat, max_lon, max_lat]

    # 1. Fetch live AIS radar signatures from external API inside the bounding box coordinates
    ais_url = f"https://api.aishub.net/v1/positions?username=YOUR_USER&format=1&bbox={sea_bounding_box[1]},{sea_bounding_box[0]},{sea_bounding_box[3]},{sea_bounding_box[2]}"
    ais_data = requests.get(ais_url).json()
    ais_coords = [(v['LONGITUDE'], v['LATITUDE']) for v in ais_data[1]]  # List of reported ships

    # 2. Grab the physical satellite radar image from Sentinel-1 for that timestamp
    s1_img = (ee.ImageCollection('COPERNICUS/S1_GRD')
              .filterBounds(roi)
              .filterDate(ee.Date(target_time).advance(-1, 'hour'), ee.Date(target_time).advance(1, 'hour'))
              .first()
              .select('VV'))

    # Bright spot thresholding algorithm to isolate physical steel hull centers
    ship_centroids = s1_img.gt(-12).reduceToVectors(scale=10, geometry=roi)
    physical_ships = ship_centroids.getInfo()['features']

    dark_vessels = []

    # 3. Cross-reference: If physical ship exists but no AIS node matches within a 500-meter buffer zone, flag it
    for ship in physical_ships:
        p_lon, p_lat = ship['geometry']['coordinates']
        match_found = any(abs(p_lon - a_lon) < 0.005 and abs(p_lat - a_lat) < 0.005 for a_lon, a_lat in ais_coords)
        if not match_found:
            dark_vessels.append({"longitude": p_lon, "latitude": p_lat, "status": "SUSPECTED_DARK_VESSEL"})

    return dark_vessels


