load_dotenv()

ee.Authenticate()
ee.Initialize(project=os.getenv('GOOGLE_PROJECT_ID'))


def analyze_urban_construction(polygon_coords, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(polygon_coords)

    collection = (ee.ImageCollection('COPERNICUS/S1_GRD')
                  .filterBounds(roi)
                  .filterDate(start_date, end_date)
                  .filter(ee.Filter.eq('instrumentMode', 'IW'))  # Interferometric Wide mode
                  .filter(ee.Filter.listContains('transmitterReceiverPolarisation', 'VV')))

    # Extract structural backscatter metrics over time
    stats = collection.map(lambda img: ee.Feature(None, {
        'date': img.date().format('YYYY-MM-DD'),
        'mean_backscatter_db': img.select('VV').reduceRegion(ee.Reducer.mean(), roi, scale=10).get('VV')
    }))
    return stats.getInfo()


