load_dotenv()

ee.Authenticate()
ee.Initialize(project=os.getenv('GOOGLE_PROJECT_ID'))


def analyze_reservoir_surface_area(polygon_coords, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(polygon_coords)
    collection = (ee.ImageCollection('LANDSAT/LC08/C02/T1_L2')
                  .filterBounds(roi)
                  .filterDate(start_date, end_date)
                  .filter(ee.Filter.lt('CLOUD_COVER', 15)))

    def calculate_mndwi(image):
        green = image.select('SR_B3')
        swir1 = image.select('SR_B6')
        mndwi = image.expression(
            '(Green - SWIR1) / (Green + SWIR1)',
            {'Green': green, 'SWIR1': swir1}
        ).rename('MNDWI')
        # Water typically has MNDWI values > 0
        water_mask = mndwi.gt(0.0)
        return image.addBands(mndwi).updateMask(water_mask)

    processed = collection.map(calculate_mndwi)

    # Calculate area of water pixels inside the reservoir polygon over time
    area_stats = processed.map(lambda img: ee.Feature(None, {
        'date': img.date().format('YYYY-MM-DD'),
        'water_area_sq_meters': img.select('MNDWI').multiply(ee.Image.pixelArea()).reduceRegion(
            reducer=ee.Reducer.sum(),
            geometry=roi,
            scale=30
        ).get('MNDWI')
    }))
    return area_stats.getInfo()


