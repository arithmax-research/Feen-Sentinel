from dotenv import load_dotenv
import os
load_dotenv()

ee.Authenticate()
ee.Initialize(project=os.getenv('GOOGLE_PROJECT_ID'))


def analyze_industrial_emissions(region_polygon, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(region_polygon)

    collection = (ee.ImageCollection('COPERNICUS/S5P/OFFL/L3_NO2')
                  .filterDate(start_date, end_date)
                  .filterBounds(roi)
                  .select('NO2_column_number_density'))

    # Map the mean atmospheric pollution signature over the industrial zone
    stats = collection.map(lambda img: ee.Feature(None, {
        'date': img.date().format('YYYY-MM-DD'),
        'mean_no2_density': img.reduceRegion(ee.Reducer.mean(), roi, scale=1000).get('NO2_column_number_density')
    }))
    return stats.getInfo()


