def analyze_floating_oil_inventory(port_polygon, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(port_polygon)

    # Use Sentinel-1 SAR to detect and volumetrically estimate floating oil storage
    collection = (ee.ImageCollection('COPERNICUS/S1_GRD')
                  .filterBounds(roi)
                  .filterDate(start_date, end_date)
                  .filter(ee.Filter.eq('instrumentMode', 'IW'))
                  .filter(ee.Filter.listContains('transmitterReceiverPolarisation', 'VV')))

    def estimate_oil_volume(image):
        # Oil on water dampens radar backscatter — dark patches indicate oil presence
        vv = image.select('VV')
        # Mask out land and normal water; retain only anomalously dark (oil-covered) water
        oil_slick_mask = vv.lt(-20).And(vv.gt(-30))
        # Area of oil slick in square meters
        oil_area = oil_slick_mask.multiply(ee.Image.pixelArea()).reduceRegion(
            reducer=ee.Reducer.sum(),
            geometry=roi,
            scale=10
        ).get('VV')
        return ee.Feature(None, {
            'date': image.date().format('YYYY-MM-DD'),
            'oil_slick_area_sq_meters': oil_area
        })

    stats = collection.map(estimate_oil_volume)
    return stats.getInfo()


