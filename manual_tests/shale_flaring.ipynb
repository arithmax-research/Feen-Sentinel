ee.Authenticate()
ee.Initialize(project=os.getenv('GOOGLE_PROJECT_ID'))


def analyze_shale_flaring(basin_polygon, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(basin_polygon)

    collection = (ee.ImageCollection('NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG')
                  .filterDate(start_date, end_date)
                  .filterBounds(roi))

    # Gas flares display immense radiance compared to ambient landscape night light
    def isolate_flares(image):
        radiance = image.select('avg_rad')
        flare_mask = radiance.gt(20.0)  # Mask background urban glow, leaving high-intensity points
        return radiance.updateMask(flare_mask)

    processed = collection.map(isolate_flares)

    stats = processed.map(lambda img: ee.Feature(None, {
        'month': img.date().format('YYYY-MM'),
        'total_flare_intensity': img.reduceRegion(ee.Reducer.sum(), roi, scale=500).get('avg_rad')
    }))
    return stats.getInfo()


