import ee
import geemap
import pandas as pd
import matplotlib.pyplot as plt
import numpy as np
import urllib.request
import io
from PIL import Image
from dotenv import load_dotenv
import os
load_dotenv()

ee.Authenticate()
ee.Initialize(project=os.getenv('GOOGLE_PROJECT_ID'))


def analyze_forestry_logging(logging_polygon, start_date, end_date):
    ee.Initialize()
    roi = ee.Geometry.Polygon(logging_polygon)

    collection = (ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
                  .filterBounds(roi)
                  .filterDate(start_date, end_date)
                  .filter(ee.Filter.lt('CLOUDY_PIXEL_PERCENTAGE', 10)))

    def calculate_nbr(image):
        nir = image.select('B8')
        swir2 = image.select('B12')
        nbr = image.expression('(B8 - B12) / (B8 + B12)', {'B8': nir, 'B12': swir2}).rename('NBR')
        # Low NBR values signify cleared ground or bare soil where trees were removed
        cleared_ground = nbr.lt(0.1)
        return image.addBands(nbr).updateMask(cleared_ground)

    processed = collection.map(calculate_nbr)

    stats = processed.map(lambda img: ee.Feature(None, {
        'date': img.date().format('YYYY-MM-DD'),
        'logged_area_sq_meters': img.select('NBR').multiply(ee.Image.pixelArea()).reduceRegion(
            reducer=ee.Reducer.sum(),
            geometry=roi,
            scale=20
        ).get('NBR')
    }))
    return stats.getInfo()


